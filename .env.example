# AI Financial Assistant — Environment Configuration
# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed.

# === LLM API ===
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# === Push Notifications ===
# Server酱 (WeChat push): https://sct.ftqq.com
SERVERCHAN_SENDKEY=your-sendkey-here
# 企业微信 (WeCom) 群机器人 Webhook (推送用)
WECOM_WEBHOOK_KEY=your-webhook-key-here

# 企业微信 自建应用 (接收消息/回调用)
# 在企微管理后台 → 应用管理 → 自建 → 获取以下信息
WECOM_CORP_ID=your-corp-id
WECOM_APP_TOKEN=your-app-token
WECOM_APP_AES_KEY=your-43-char-encoding-aes-key

# === Data Directory (optional) ===
# Path to your financial data files.
# - Leave unset / comment out → uses finance_demo/ (demo data, git-tracked)
# - Set to "finance" → uses finance/ (gitignored, for your real data)
# - Set to any absolute path for external storage outside the repo
# FINANCE_DATA_DIR=D:/MyFinancialData/
